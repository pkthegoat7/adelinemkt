# ─────────────────────────────────────────────────────────────
# Adelina · Prospecção — variáveis de ambiente
# Copie para ".env" (local) ou configure no painel do Railway.
# ─────────────────────────────────────────────────────────────

# Porta (o Railway injeta PORT automaticamente; deixe em branco lá)
PORT=3000

# URL pública do app, usada nos links de descadastro do e-mail.
# No Railway, algo como https://seu-app.up.railway.app
PUBLIC_URL=http://localhost:3000

# Senha simples para acessar o painel (Basic Auth). Troque!
ADMIN_USER=admin
ADMIN_PASS=troque-esta-senha

# Caminho do banco SQLite. No Railway, monte um Volume em /data
# e use /data/adelina.json para os dados sobreviverem a deploys.
DB_PATH=./data/adelina.json

# ── E-MAIL (SMTP) ────────────────────────────────────────────
# Funciona com qualquer provedor transacional. Exemplos:
#   Resend:  host=smtp.resend.com  port=465  user=resend  pass=API_KEY
#   Brevo:   host=smtp-relay.brevo.com  port=587  user=...  pass=...
#   SES:     host=email-smtp.us-east-1.amazonaws.com  port=587 ...
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Remetente. Use um e-mail do SEU domínio já verificado (SPF/DKIM).
MAIL_FROM_NAME=Adelina
MAIL_FROM_EMAIL=contato@seudominio.com.br
# E-mail que recebe respostas (opcional)
MAIL_REPLY_TO=

# Intervalo entre envios de e-mail, em segundos (anti-spam/reputação)
EMAIL_THROTTLE_SECONDS=8

# ── WHATSAPP (Cloud API oficial da Meta) ─────────────────────
# Opcional. Sem isso, o painel usa links wa.me (envio com 1 clique).
# Cloud API exige WhatsApp Business + template aprovado para
# mensagens frias (fora da janela de 24h).
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=pt_BR
